               <span aria-hidden="true">&times;</span>
            </button>
            <h4 class="modal-title">
               <i class="fa fa-magic" aria-hidden="true"></i>
               Generar datos de prueba
            </h4>
            <p class="help-block">Selecciona qué datos quieres generar.</p>
         </div>
         <div class="modal-body">
            <div class="row">
               <div class="col-sm-4">
                  <a href="{{ fsc.url() }}&gdp=fabricantes" class="btn btn-sm btn-block btn-default"><i class="fa fa-folder" aria-hidden="true"></i> Fabricantes</a>
                  <br />
                  <a href="{{ fsc.url() }}&gdp=familias" class="btn btn-sm btn-block btn-default"><i class="fa fa-folder" aria-hidden="true"></i> Familias</a>
                  <br />
                  <a href="{{ fsc.url() }}&gdp=articulos" class="btn btn-sm btn-block btn-default"><i class="fa fa-cubes" aria-hidden="true"></i> Artículos</a>
                  <br />
                  <a href="{{ fsc.url() }}&gdp=agentes" class="btn btn-sm btn-block btn-default"><i class="fa fa-users" aria-hidden="true"></i> Empleados</a>
                  <br />
               </div>
               <div class="col-sm-4">
                  <a href="{{ fsc.url() }}&gdp=proveedores" class="btn btn-sm btn-block btn-default"><i class="fa fa-users" aria-hidden="true"></i> Proveedores</a>
                  <br />
                  <a href="{{ fsc.url() }}&gdp=albaranesprov" class="btn btn-sm btn-block btn-default"><i class="fa fa-copy" aria-hidden="true"></i> {{ constant('FS_ALBARANES') }} de compra</a>
                  <br />
                  <a href="{{ fsc.url() }}&gdp=pedidosprov" class="btn btn-sm btn-block btn-default"><i class="fa fa-copy" aria-hidden="true"></i> {{ constant('FS_PEDIDOS') }} de compra</a>
                  <br />
               </div>
               <div class="col-sm-4">
                  <a href="{{ fsc.url() }}&gdp=gruposcli" class="btn btn-sm btn-block btn-default"><i class="fa fa-folder" aria-hidden="true"></i> Grupos de clientes</a>
                  <br />
                  <a href="{{ fsc.url() }}&gdp=clientes" class="btn btn-sm btn-block btn-default"><i class="fa fa-users" aria-hidden="true"></i> Clientes</a>
                  <br />
                  <a href="{{ fsc.url() }}&gdp=albaranescli" class="btn btn-sm btn-block btn-default"><i class="fa fa-copy" aria-hidden="true"></i> {{ constant('FS_ALBARANES') }} de venta</a>
                  <br />
                  <a href="{{ fsc.url() }}&gdp=pedidoscli" class="btn btn-sm btn-block btn-default"><i class="fa fa-copy" aria-hidden="true"></i> {{ constant('FS_PEDIDOS') }} de venta</a>
                  <br />
                  <a href="{{ fsc.url() }}&gdp=presupuestoscli" class="btn btn-sm btn-block btn-default"><i class="fa fa-copy" aria-hidden="true"></i> {{ constant('FS_PRESUPUESTOS') }} de venta</a>
                  <br />
                  <a href="{{ fsc.url() }}&gdp=servicioscli" class="btn btn-sm btn-block btn-default"><i class="fa fa-copy" aria-hidden="true"></i> {{ constant('FS_SERVICIOS') }} a clientes</a>
                  <br />
               </div>
            </div>
            <div class="row">
               {% for extension in fsc.extensions %}
               {% if extension.type == 'generate' %}
               <div class="col-sm-4">
                  <a href="index.php?page={{ extension.from }}{{ extension.params }}" class="btn btn-sm btn-block btn-default">{{ extension.text }}</a>
               </div>
               {% endif %}
               {% endfor %}
            </div>
            <div class="row">
               <div class="col-sm-12">
                  <div class="alert alert-warning">
                     <i class="fa fa-warning" aria-hidden="true"></i>
                     La generación de datos de prueba sirve para demos y para probar los plugins con datos masivos.
                     No continues si no sabes lo que haces.
                  </div>
               </div>
            </div>
         </div>
      </div>
   </div>
</div>

<div class="modal fade" id="modal_tablas" tabindex="-1" role="dialog">
   <div class="modal-dialog modal-lg" role="document">
      <div class="modal-content">
         <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
               <span aria-hidden="true">&times;</span>
            </button>
            <h4 class="modal-title">
               <i class="fa fa-database" aria-hidden="true"></i>
               Tablas
            </h4>
            <p class="help-block">Selecciona una tabla para ver las opciones de generación.</p>
         </div>
         <div class="modal-body">
            <div class="row">
               {% for tabla in fsc.tablas %}
               <div class="col-sm-4">
                  <a href="index.php?page=fsdk_tabla&table={{ tabla.name }}" class="btn btn-sm btn-block btn-default">
                     <i class="fa fa-folder" aria-hidden="true"></i> {{ tabla.name }}
                  </a>
                  <br />
               </div>
               {% endfor %}
            </div>
         </div>
      </div>
   </div>
</div>

<form class="form" role="form" name="f_nuevo_plugin" action="{{ fsc.url() }}" method="post">
   {{ csrf_field() }}
   <input type="hidden" name="generarplugin" value="1">
   <div class="modal" id="modal_nuevo_plugin" tabindex="-1" role="dialog">
      <div class="modal-dialog" role="document">
         <div class="modal-content">
            <div class="modal-header">
               <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
               </button>
               <h4 class="modal-title">
                  <i class="fa fa-puzzle-piece" aria-hidden="true"></i>
                  Nuevo plugin
               </h4>
               <p class="help-block">Genera un nuevo plugin para que puedas empezar a modificarlo.</p>
            </div>
            <div class="modal-body">
               <div class="form-group">
                  Nombre:
                  <input type="text" name="nombre" value="holamundo" class="form-control" autofocus=""
                     autocomplete="off" />
               </div>
               <div class="form-group">
                  Descripción:
                  <textarea name="descripcion" class="form-control" rows="4"></textarea>
               </div>
            </div>
            <div class="modal-footer">
               <button class="btn btn-sm btn-primary" type="submit">
                  <i class="fa fa-puzzle-piece" aria-hidden="true"></i>&nbsp; Generar
               </button>
            </div>
         </div>
      </div>
   </div>
</form>

<form action="{{ fsc.url() }}" method="post"
   onsubmit="return confirm('¿Estás seguro de que quieres eliminar las tablas de los plugins seleccionados? Esta acción no se puede deshacer.')">
   {{ csrf_field() }}
   <input type="hidden" name="clean_plugin_tables" value="TRUE">
   <div class="modal fade" id="modal_clean_tables" tabindex="-1" role="dialog">
      <div class="modal-dialog modal-lg" role="document">
         <div class="modal-content">
            <div class="modal-header">
               <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
               </button>
               <h4 class="modal-title">
                  <i class="fa fa-trash-o" aria-hidden="true"></i>
                  Limpiar tablas de plugins desactivados
               </h4>
               <p class="help-block">Secciona los plugins de los que quieres eliminar las tablas.</p>
            </div>
            <div class="modal-body">
               {% if fsc.plugins_desactivados is empty %}
               <div class="alert alert-info">
                  <i class="fa fa-info-circle" aria-hidden="true"></i>
                  No se encontraron plugins desactivados con tablas en la base de datos.
               </div>
               {% else %}
               <div class="alert alert-warning">
                  <i class="fa fa-exclamation-triangle" aria-hidden="true"></i>
                  <strong>¡Atención!</strong> Esta acción eliminará permanentemente las tablas seleccionadas de la base de datos.
                  Asegúrate de tener un backup antes de continuar.
               </div>
               <div class="table-responsive">
                  <table class="table table-striped">
                     <thead>
                        <tr>
                           <th style="width: 40px;">
                              <input type="checkbox" id="select_all_plugins" onclick="toggleAllPlugins()">
                           </th>
                           <th>Plugin</th>
                           <th>Tablas a eliminar</th>
                           <th>Cantidad</th>
                           <th>Acción individual</th>
                        </tr>
                     </thead>
                     <tbody>
                        {% for plugin in fsc.plugins_desactivados %}
                        <tr>
                           <td>
                              <input type="checkbox" name="plugins_seleccionados[]" value="{{ plugin.nombre }}"
                                 class="plugin-checkbox">
                           </td>
                           <td><strong>{{ plugin.nombre }}</strong></td>
                           <td>{{ plugin.tablas_texto }}</td>
                           <td>{{ plugin.num_tablas }}</td>
                           <td>
                              <a href="{{ fsc.url() }}&clean_plugin_tables=TRUE&plugins={{ plugin.nombre }}"
                                 class="btn btn-xs btn-danger"
                                 onclick="return confirm('¿Eliminar solo las tablas del plugin {{ plugin.nombre|e('js') }}?')">
                                 <i class="fa fa-trash-o" aria-hidden="true"></i> Solo este
                              </a>
                           </td>
                        </tr>
                        {% endfor %}
                     </tbody>
                     <tfoot>
                        <tr class="info">
                           <td></td>
                           <td><strong>Total de tablas:</strong></td>
                           <td></td>
                           <td><strong>{{ fsc.total_tablas_a_eliminar }}</strong></td>
                           <td></td>
                        </tr>
                     </tfoot>
                  </table>
               </div>
               {% endif %}
            </div>
            <div class="modal-footer">
               {% if fsc.plugins_desactivados is not empty %}
               <button type="submit" class="btn btn-danger">
                  <i class="fa fa-trash-o" aria-hidden="true"></i> Eliminar tablas de plugins seleccionados
               </button>
               {% endif %}
               <button type="button" class="btn btn-default" data-dismiss="modal">Cerrar</button>
            </div>
         </div>
      </div>
   </div>
</form>

<script>
   function toggleAllPlugins() {
      var checkboxes = document.querySelectorAll('.plugin-checkbox');
      var selectAll = document.getElementById('select_all_plugins');
      for (var i = 0; i < checkboxes.length; i++) {
         checkboxes[i].checked = selectAll.checked;
      }
   }
</script>

<form action="{{ fsc.url() }}" method="post" id="form_resetear_framework">
   {{ csrf_field() }}
   <input type="hidden" name="resetear_framework" value="TRUE">
   <div class="modal fade" id="modal_resetear_framework" tabindex="-1" role="dialog">
      <div class="modal-dialog" role="document">
         <div class="modal-content">
            <div class="modal-header">
               <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
               </button>
               <h4 class="modal-title">
                  <i class="fa fa-bomb" aria-hidden="true"></i>
                  Resetear framework
               </h4>
            </div>
            <div class="modal-body">
               <div class="alert alert-danger">
                  <i class="fa fa-exclamation-triangle" aria-hidden="true"></i>
                  <strong>¡ATENCIÓN! Esta acción es irreversible.</strong><br />
                  Se eliminarán <strong>todas las tablas</strong> de la base de datos y el archivo
                  <code>config.php</code>.<br />
                  El framework volverá al estado de instalación inicial y perderás todos los datos.
               </div>
               <div class="form-group">
                  <label for="confirmar_reset">Escribe <strong>RESETEAR</strong> para confirmar:</label>
                  <input type="text" name="confirmar_reset" id="confirmar_reset" class="form-control" autocomplete="off"
                     placeholder="Escribe RESETEAR aquí">
               </div>
            </div>
            <div class="modal-footer">
               <button type="button" class="btn btn-default" data-dismiss="modal">Cancelar</button>
               <button type="submit" class="btn btn-danger" id="btn_resetear" disabled>
                  <i class="fa fa-bomb" aria-hidden="true"></i> Resetear framework
               </button>
            </div>
         </div>
      </div>
   </div>
</form>

<script>
   $(document).ready(function () {
      $('#confirmar_reset').on('input', function () {
         $('#btn_resetear').prop('disabled', $(this).val() !== 'RESETEAR');
      });
   });
</script>

{% include 'footer.html.twig' %}