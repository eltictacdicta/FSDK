{% include 'header.html.twig' %}

<div class="container-fluid">
   <div class="row">
      <div class="col-sm-12">
         <div class="page-header">
            <h1>
               <i class="fa fa-graduation-cap" aria-hidden="true"></i>
               {{ fsc.texto }}
               <span class="btn-group">
                  <a class="btn btn-xs btn-default" href="{{ fsc.url() }}" title="Recargar la página">
                     <span class="glyphicon glyphicon-refresh"></span>
                  </a>
                  {% if fsc.page.is_default() %}
                  <a class="btn btn-xs btn-default active" href="{{ fsc.url() }}&default_page=FALSE" title="desmarcar como página de inicio">
                     <span class="glyphicon glyphicon-home"></span>
                  </a>
                  {% else %}
                  <a class="btn btn-xs btn-default" href="{{ fsc.url() }}&default_page=TRUE" title="marcar como página de inicio">
                     <span class="glyphicon glyphicon-home"></span>
                  </a>
                  {% endif %}
               </span>
            </h1>
            <p class="help-block">{{ fsc.texto2 }}</p>
         </div>
      </div>
   </div>
   <div class="row">
      <div class="col-sm-6">
         <p class="help-block">Ahora vamos a mostrar los datos de la lista con la función <b>for</b>.</p>
         <ul>
            {% for item in fsc.lista %}
            <li>{{ item }}</li>
            {% endfor %}
         </ul>
      </div>
      <div class="col-sm-6">
         <p class="help-block"><b>for</b> también expone el contador <code>loop.index0</code>, que empieza en 0.</p>
         <ul>
            {% for item in fsc.lista %}
            <li><b>{{ loop.index0 }}</b> {{ item }}</li>
            {% endfor %}
         </ul>
      </div>
   </div>
   <div class="row">
      <div class="col-sm-12">
         <h4>
            Y ahora vamos a mostrar en una tabla los resultados de la consulta
            <mark>select * from paises;</mark>
         </h4>
         <div class="table-responsive">
            <table class="table table-hover">
               <thead>
                  <tr>
                     <th>Codpais</th>
                     <th>ISO</th>
                     <th>Nombre</th>
                  </tr>
               </thead>
               <tbody>
               {% for fila in fsc.resultados_sql %}
               <tr>
                  <td>{{ fila.codpais }}</td>
                  <td>{{ fila.codiso }}</td>
                  <td>{{ fila.nombre }}</td>
               </tr>
               {% endfor %}
               </tbody>
            </table>
         </div>
      </div>
   </div>
</div>

{% include 'footer.html.twig' %}